generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role               String   @default("user")
  mustChangePassword Boolean  @default(false)
  emailVerified      Boolean  @default(false)
  verificationToken  String?  @unique
  verificationTokenExpires DateTime?
  stripeCustomerId   String?  @unique
  createdAt          DateTime @default(now())

  orders              Order[]
  messages            Message[]
  orderViews          OrderView[]
  passwordResetTokens PasswordResetToken[]
  addresses           Address[]
  reviews             Review[]
  bookings            Booking[]
  shopOrders          ShopOrder[]
}

model Order {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         String   @default("pending")
  orderType      String?
  orderNumber    String?
  description    String
  quantity       Int      @default(1)
  trackingNumber String?
  carrier        String?
  trackingStatus String?
  trackingUrl    String?
  labelUrl       String?
  quote          Float?
  paymentStatus  String?
  paymentMethod  String?   // 'card' (paid in full) or 'check' (deposit + balance by check)
  depositPaid    Boolean   @default(false)
  depositWaived  Boolean   @default(false)
  stripeSessionId String?
  createdAt      DateTime @default(now())
  archivedAt     DateTime?
  deletedAt      DateTime?

  adminNotes    String?
  customerNotes String?
  messages      Message[]
  files         FileUpload[]
  orderViews    OrderView[]
  quoteHistory  QuoteHistory[]
  events        OrderEvent[]
  photos        OrderPhoto[]

  @@index([userId, createdAt])
}

model Message {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  fileUrl   String?
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([senderId])
}

model FileUpload {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  url       String
  name      String?
  createdAt DateTime @default(now())

  @@index([orderId])
}

model PasswordResetRequest {
  id        String   @id @default(cuid())
  email     String
  name      String
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuoteHistory {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount    Float
  createdAt DateTime @default(now())

  @@index([orderId])
}

model OrderView {
  userId   String
  orderId  String
  viewedAt DateTime @default(now()) @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@id([userId, orderId])
}

model OrderEvent {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type        String
  description String
  createdAt   DateTime @default(now())

  @@index([orderId])
}

model OrderPhoto {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  category  String?
  createdAt DateTime @default(now())

  @@index([orderId])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  street    String
  city      String
  state     String
  zip       String
  country   String   @default("US")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  inStock     Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Set only on products pulled from Etsy. Products created by hand keep this
  // null and are never touched by the sync.
  etsyListingId String?   @unique
  etsyUrl       String?
  etsySyncedAt  DateTime?

  // Shipping. processingMin/Max come from the listing itself, not the shipping
  // profile, which leaves them unset.
  processingMin Int?
  processingMax Int?
  shipsFrom     String?
  shippingCost  Float?
  shippingMinDays Int?
  shippingMaxDays Int?

  // Listing detail mirrored from Etsy.
  tags          String[] @default([])
  materials     String[] @default([])
  whoMade       String?  // e.g. "i_did"
  whenMade      String?  // e.g. "made_to_order"
  itemWeight    Float?
  itemWeightUnit String?
  itemLength    Float?
  itemWidth     Float?
  itemHeight    Float?
  itemDimensionsUnit String?
  isPersonalizable Boolean @default(false)
  personalizationInstructions String?
  numFavorers   Int?
  etsyViews     Int?
  hasVariations Boolean @default(false)

  images      ProductImage[]
  variations  ProductVariation[]
  reviews     Review[]
  etsyReviews EtsyReview[]
  backInStock BackInStockSubscription[]
}

// A review left on Etsy, mirrored read-only. Kept separate from Review, which is
// written by signed-in customers on this site and is tied to a User.
model EtsyReview {
  id            String   @id @default(cuid())
  // Etsy's per-transaction id: the only stable key it gives us, so it doubles as
  // the dedupe key across syncs.
  transactionId String   @unique
  etsyListingId String?
  productId     String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  rating        Int
  review        String?
  imageUrl      String?
  reviewedAt    DateTime
  syncedAt      DateTime @default(now())

  @@index([productId, reviewedAt])
}

// A buyable combination from the listing's Etsy inventory, e.g. Primary color:
// Army Blue. Options are stored as [{ name, value }] because Etsy lets a listing
// vary on arbitrary properties, not just colour.
model ProductVariation {
  id            String  @id @default(cuid())
  productId     String
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  etsyProductId String?
  sku           String?
  price         Float?
  quantity      Int     @default(0)
  isEnabled     Boolean @default(true)
  label         String  // flattened for display, e.g. "Army Blue"
  options       Json    @default("[]")
  rank          Int     @default(0)

  @@index([productId, rank])
}

// Every image on a listing, ordered as Etsy ranks them. Product.imageUrl stays as
// the primary thumbnail so existing grid/cart code keeps working.
model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  fullUrl   String?
  rank      Int     @default(0)

  @@index([productId, rank])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  // A customer-uploaded photo of the item they received.
  imageUrl  String?
  // True when the reviewer has a matching paid order for this product.
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([productId, userId])
}

// A purchase from the Shop. Created as "pending" when checkout starts and marked
// "paid" by the Stripe webhook, so the exact items and prices charged are recorded
// without relying on Stripe metadata size limits.
model ShopOrder {
  id              String    @id @default(cuid())
  orderNumber     String?   @unique
  // Null for guest checkout: purchases are still recorded, just not tied to a login.
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  email           String?
  status          String    @default("pending") // pending | paid | shipped | delivered | cancelled
  total           Float
  stripeSessionId String?   @unique
  createdAt       DateTime  @default(now())
  paidAt          DateTime?

  items ShopOrderItem[]

  @@index([userId, createdAt])
  @@index([email])
}

// Name and price are snapshots taken at purchase time: the product may later be
// edited or deleted, but the receipt must not change.
model ShopOrderItem {
  id          String    @id @default(cuid())
  shopOrderId String
  shopOrder   ShopOrder @relation(fields: [shopOrderId], references: [id], onDelete: Cascade)
  productId   String?
  name        String
  // Which variation was bought, e.g. "Army Blue". Snapshotted like name/price so
  // the order always records what was actually ordered.
  variation   String?
  price       Float
  quantity    Int

  @@index([shopOrderId])
}

// An Etsy order (receipt), mirrored so it can be fulfilled and shipped from this
// site. Buyer name/address are the seller's own order data.
model EtsyOrder {
  id               String   @id @default(cuid())
  receiptId        String   @unique
  buyerName        String?
  status           String?
  isPaid           Boolean  @default(false)
  isShipped        Boolean  @default(false)
  grandTotal       Float?
  currency         String?
  addrLine1        String?
  addrLine2        String?
  addrCity         String?
  addrState        String?
  addrZip          String?
  addrCountry      String?
  formattedAddress String?
  messageFromBuyer String?
  // Tracking, from Etsy's own shipments or pushed here after a Shippo label buy.
  trackingCode     String?
  carrier          String?
  labelUrl         String?
  labelCost        Float?
  // Shipping-label cost for a label bought on Etsy, attributed from the ledger.
  // (labelCost above is for labels bought in-app via Shippo and takes precedence.)
  etsyLabelCost    Float?
  // Exact Etsy fees for this order, summed from the payment-account ledger.
  etsyFees         Float?
  salesTax         Float?
  feesSyncedAt     DateTime?
  orderedAt        DateTime
  syncedAt         DateTime @default(now())

  items EtsyOrderItem[]

  @@index([isShipped, orderedAt])
}

model EtsyOrderItem {
  id            String    @id @default(cuid())
  etsyOrderId   String
  order         EtsyOrder @relation(fields: [etsyOrderId], references: [id], onDelete: Cascade)
  transactionId String    @unique
  title         String
  quantity      Int
  price         Float?
  variations    String?
  listingId     String?
  productId     String?

  @@index([etsyOrderId])
}

// Single stored Etsy OAuth grant (this site connects one shop). Access tokens
// last an hour and are refreshed on demand; refresh tokens rotate on each use.
model EtsyToken {
  id           String   @id @default("shop")
  shopId       String
  accessToken  String
  refreshToken String
  scope        String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Short-lived PKCE state for an in-flight OAuth authorization. Consumed by the
// callback; stale rows are swept on the next connect.
model EtsyOAuthState {
  state        String   @id
  codeVerifier String
  createdAt    DateTime @default(now())
}

model GalleryPhoto {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  category  String?
  createdAt DateTime @default(now())
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  type          String
  value         Float
  maxUses       Int?
  uses          Int       @default(0)
  expiresAt     DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  minQuantity   Int?
  minOrderValue Float?
}

model AvailabilitySlot {
  id        String   @id @default(cuid())
  startsAt  DateTime
  duration  Int      // minutes: 15 or 30
  createdAt DateTime @default(now())
  booking   Booking?
}

model Booking {
  id        String           @id @default(cuid())
  slotId    String           @unique
  slot      AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  topic     String?
  createdAt DateTime         @default(now())
}

// Cross-instance rate limiting. One row per (action, client, time-window); the
// count is bumped per request. Shared Postgres means serverless instances all
// see the same counter, unlike the previous in-memory map.
model RateLimit {
  key       String   @id
  count     Int      @default(0)
  expiresAt DateTime

  @@index([expiresAt])
}

// A customer asking to be emailed when an out-of-stock product is available again.
model BackInStockSubscription {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  email       String
  createdAt   DateTime  @default(now())
  notifiedAt  DateTime?

  @@unique([productId, email])
  @@index([productId, notifiedAt])
}
